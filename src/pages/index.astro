---
// Home / Hero page
// Edit content at: content/home/home.json (or via TinaCMS admin)
import BaseLayout from "../layouts/BaseLayout.astro";
import homeData from "../../content/home/home.json";

const { name, subtitle, photo, tagline, bookingUrl, ctaLabel } = homeData;
const taglineParagraphs = tagline.split("\n\n");
---

<BaseLayout title={name}>
  <main class="hero page">
    <div class="hero__content">
      <p class="hero__sub">{subtitle}</p>
      <h1 class="hero__title">{name}</h1>
      <hr class="rule hero__rule" />
      <div class="hero__tagline">
        {taglineParagraphs.map((para) => (
          <p class="hero__para">{para}</p>
        ))}
      </div>
      <a href={bookingUrl} class="btn">{ctaLabel}</a>
    </div>
    <div class="hero__photo-wrap">
      <img class="hero__photo" src={photo} alt={name} />
    </div>
  </main>
</BaseLayout>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 2rem;
  }

  .hero__sub {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero__title {
    font-size: clamp(3.5rem, 10vw, 6rem);
  }

  .hero__rule {
    width: 3rem;
    border-top-color: var(--color-accent);
  }

  .hero__tagline {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero__para {
    white-space: pre-line;
    line-height: 2;
  }

  .hero__photo-wrap {
    align-self: stretch;
    min-height: 420px;
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  @media (max-width: 600px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero__content {
      align-items: center;
      text-align: center;
    }

    .hero__photo-wrap {
      min-height: 300px;
    }
  }
</style>
