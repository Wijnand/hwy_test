---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const navLinks = [
  { href: `${base}/`,              label: "Home" },
  { href: `${base}/over-mij`,      label: "Over mij" },
  { href: `${base}/behandelingen`, label: "Behandelingen" },
  { href: `${base}/contact`,       label: "Contact" },
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav__inner">
      <a href={`${base}/`} class="nav__logo">
        <img src={`${base}/logo.png`} alt="Home Within Yourself" />
      </a>
      <ul class="nav__list">
        {navLinks.map(({ href, label }) => {
          const active = currentPath === href || currentPath === href + "/" || currentPath === href.replace(/\/$/, "");
          return (
            <li>
              <a href={href} class:list={["nav__link", { "nav__link--active": active }]}>
                {label}
              </a>
            </li>
          );
        })}
      </ul>
      </div>
    </nav>
    <slot />
  </body>
</html>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-rule);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav__logo img {
    height: 2rem;
    width: auto;
    display: block;
  }

  .nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2.5rem;
  }

  .nav__link {
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    opacity: 0.65;
    transition: opacity 0.2s;
  }

  .nav__link:hover {
    opacity: 1;
  }

  .nav__link--active {
    opacity: 1;
    color: var(--color-accent);
  }
</style>
